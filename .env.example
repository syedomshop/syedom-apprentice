# Syedom Labs Internship Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# All VITE_ prefixed variables are exposed to the frontend browser bundle.
# Never put secrets (service role key, etc.) in VITE_ variables.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Supabase Edge Functions (server-side only — set in Supabase dashboard) ─
# These are NOT VITE_ prefixed and are injected into edge functions at runtime.
# Set them in: Supabase Dashboard → Edge Functions → Secrets
# GEMINI_API_KEY=your-gemini-api-key
# RESEND_API_KEY=your-resend-api-key
# SUPABASE_SERVICE_ROLE_KEY=auto-injected-by-supabase

# ─── Vercel Deployment ─────────────────────────────────────────────────────
# Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in:
# Vercel Dashboard → Project → Settings → Environment Variables
